# ==============================================================================
# LLM Auto-Troubleshooter for Bash
# ==============================================================================

shopt -s extdebug

# Load Configuration
LLM_CONFIG_PATH="$HOME/.llm_config"
if [[ -f "$LLM_CONFIG_PATH" ]]; then
    source "$LLM_CONFIG_PATH"
fi

# Set Defaults if not provided in .llm_config
export LLM_PROVIDER="${LLM_PROVIDER:-ollama}"
export LLM_MODEL="${LLM_MODEL:-tinyllama}"
export LLM_OLLAMA_URL="${LLM_OLLAMA_URL:-http://localhost:11434/api/generate}"

__llm_troubleshoot() {
    local cmd="$1"
    local exit_status="$2"
    local out_file="$3"
    local err_file="$4"

    echo -e "\n\e[1;35m[🤖 LLM is analyzing the error using ${LLM_PROVIDER}...]\e[0m"

    local prompt="The user ran: \`$cmd\` (Exit Code: $exit_status).
STDOUT: $(cat "$out_file" | tail -c 1000)
STDERR: $(cat "$err_file" | tail -c 1000)
Explain the error and provide the fix command. Be extremely brief."

    local response=""
    local llm_answer=""

    case "$LLM_PROVIDER" in
        openai)
            response=$(curl -s https://api.openai.com/v1/chat/completions \
                -H "Content-Type: application/json" \
                -H "Authorization: Bearer $LLM_API_KEY" \
                -d "$(jq -n --arg m "$LLM_MODEL" --arg p "$prompt" '{model: $m, messages: [{role: "user", content: $p}]}')")
            llm_answer=$(echo "$response" | jq -r '.choices[0].message.content // "Error: Check API Key/Quota"')
            ;;
        anthropic)
            response=$(curl -s https://api.anthropic.com/v1/messages \
                -H "x-api-key: $LLM_API_KEY" \
                -H "anthropic-version: 2023-06-01" \
                -H "content-type: application/json" \
                -d "$(jq -n --arg m "$LLM_MODEL" --arg p "$prompt" '{model: $m, max_tokens: 1024, messages: [{role: "user", content: $p}]}')")
            llm_answer=$(echo "$response" | jq -r '.content[0].text // "Error: Check Anthropic Key"')
            ;;
        gemini)
            response=$(curl -s -X POST "https://generativelanguage.googleapis.com/v1beta/models/${LLM_MODEL}:generateContent?key=${LLM_API_KEY}" \
                -H "Content-Type: application/json" \
                -d "$(jq -n --arg p "$prompt" '{contents: [{parts: [{text: $p}]}]}')")
            llm_answer=$(echo "$response" | jq -r '.candidates[0].content.parts[0].text // "Error: Check Gemini Key"')
            ;;
        *) # Default: Ollama
            response=$(curl -s -X POST "$LLM_OLLAMA_URL" \
                -d "$(jq -n --arg m "$LLM_MODEL" --arg p "$prompt" '{model: $m, prompt: $p, stream: false}')")
            llm_answer=$(echo "$response" | jq -r '.response // "Ollama error: Is the service running?"')
            ;;
    esac

    echo -e "\e[1;32m$llm_answer\e[0m\n"
}

__llm_wrapper() {
    if [[ $BASH_SUBSHELL -ne 0 || -n "$__IN_LLM_WRAPPER" ]]; then return 0; fi

    local cmd="$BASH_COMMAND"
    if [[ -z "$cmd" || "$cmd" == "PROMPT_COMMAND"* || "$cmd" == "history"* ]]; then return 0; fi

    # Exclude UI/Interactive tools
    local first_word="${cmd%% *}"
    case "$first_word" in
        vi|vim|nvim|nano|top|htop|ssh|tmux|screen|git|less|more|man|sudo|clear) return 0 ;;
    esac

    export __IN_LLM_WRAPPER=1
    local out_file=$(mktemp)
    local err_file=$(mktemp)

    # Execute and capture
    eval "$cmd" > >(tee "$out_file") 2> >(tee "$err_file" >&2)
    local exit_status=$?

    if [[ $exit_status -ne 0 ]]; then
        __llm_troubleshoot "$cmd" "$exit_status" "$out_file" "$err_file"
    fi

    rm -f "$out_file" "$err_file"
    unset __IN_LLM_WRAPPER
    return 1 # Skip original execution
}

trap '__llm_wrapper' DEBUG